rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : null;
    }

    function isInstitutionalEmail() {
      return request.auth.token.email.matches(".*@neu\\.edu\\.ph$");
    }

    function isPreAuthAdmin() {
      return exists(/databases/$(database)/documents/preauthorized_admins/$(request.auth.token.email.lower()));
    }

    function isAdmin() {
      let data = getUserData();
      return isAuthenticated() && isInstitutionalEmail() && (
        (data != null && data.role == 'admin') || 
        (request.auth.token.email == "mariaantonette.espinosa@neu.edu.ph" && request.auth.token.email_verified == true) ||
        isPreAuthAdmin()
      );
    }

    function isNotBlocked() {
      let data = getUserData();
      return data == null || data.isBlocked != true;
    }

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // User: { uid, email, displayName, role, isBlocked, universityId }
    // Log: { userId, userName, roomNumber, timestamp, entryMethod }
    // Room: { roomNumber, buildingName }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'displayName', 'isBlocked', 'universityId']) &&
             data.uid is string &&
             data.email is string &&
             data.email.size() < 100 &&
             data.email.matches(".*@neu\\.edu\\.ph$") &&
             data.role in ['admin', 'professor'] &&
             data.displayName is string &&
             data.isBlocked is bool &&
             data.universityId is string;
    }

    function isValidLog(data) {
      return data.keys().hasAll(['userId', 'roomNumber', 'timestamp', 'entryMethod']) &&
             data.userId is string &&
             data.roomNumber is string &&
             data.timestamp is string &&
             data.entryMethod in ['qr', 'email'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && isInstitutionalEmail();
      allow create: if isAuthenticated() && isInstitutionalEmail() && isOwner(userId) && isValidUser(request.resource.data) && 
                    (request.resource.data.role == 'professor' || (request.resource.data.role == 'admin' && isAdmin()));
      allow update: if (isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role && request.resource.data.isBlocked == resource.data.isBlocked)) && isInstitutionalEmail();
      allow delete: if isAdmin();
    }

    match /logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && isInstitutionalEmail() && isNotBlocked() && isValidLog(request.resource.data) && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /rooms/{roomId} {
      allow read: if isAuthenticated() && isInstitutionalEmail();
      allow write: if isAdmin();
    }

    match /preauthorized_admins/{email} {
      allow read: if isAuthenticated() && isInstitutionalEmail();
      allow write: if isAdmin();
    }
  }
}
